# WG-LAN Configuration

# Secret key for JWT signing (CHANGE THIS in production)
WG_LAN_SECRET_KEY=change-me-to-a-random-string

# Default admin password (only used on first run)
WG_LAN_ADMIN_PASSWORD=admin123

# WireGuard server settings
WG_LAN_SERVER_ENDPOINT=vpn.example.com
WG_LAN_SERVER_PORT=51820
WG_LAN_SUBNET=10.50.0.0/24

# Dashboard settings
WG_LAN_HOST=0.0.0.0
WG_LAN_PORT=5000
WG_LAN_DEBUG=false

# Database
WG_LAN_DB_PATH=./data/wg-lan.db

# WireGuard config path
WG_LAN_WG_CONFIG_PATH=/etc/wireguard
WG_LAN_WG_INTERFACE=wg0
