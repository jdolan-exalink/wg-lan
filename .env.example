# NetLoom Configuration

# Secret key for JWT signing (CHANGE THIS in production)
NETLOOM_SECRET_KEY=change-me-to-a-random-string

# Default admin password (only used on first run)
NETLOOM_ADMIN_PASSWORD=admin123

# WireGuard server settings
NETLOOM_SERVER_ENDPOINT=vpn.example.com
NETLOOM_SERVER_PORT=51820
NETLOOM_SUBNET=100.169.0.0/16

# Dashboard settings
NETLOOM_HOST=0.0.0.0
NETLOOM_PORT=7777
NETLOOM_DEBUG=false

# Database
NETLOOM_DB_PATH=./data/netloom.db

# WireGuard config path
NETLOOM_WG_CONFIG_PATH=/etc/wireguard
NETLOOM_WG_INTERFACE=wg0
